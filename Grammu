-- ROLE COLOR (ตรงแมพ)
local function GetColor(role)
    role = role:lower()

    if role:find("class") then return Color3.fromRGB(255,170,0)
    elseif role:find("foundation") then return Color3.fromRGB(255,255,255)
    elseif role:find("security") then return Color3.fromRGB(0,170,255)
    elseif role:find("mtf") then return Color3.fromRGB(0,120,255)
    elseif role:find("chaos") then return Color3.fromRGB(0,255,0)
    elseif role:find("goc") then return Color3.fromRGB(255,255,0)
    elseif role:find("serpent") then return Color3.fromRGB(255,0,0)
    elseif role:find("scp") then return Color3.fromRGB(255,105,180)
    end

    return Color3.fromRGB(255,255,255)
end

-- ALLIANCE SYSTEM
local Alliances = {
    Foundation = {"foundation","mtf","security","guard","fp","sd"},
    Chaos = {"chaos","ci","cd","class"},
    SCP = {"scp","serpent"},
    Neutral = {"goc"}
}

local function GetRole(p)
    return (p.Team and p.Team.Name) or "Unknown"
end

local function GetAlliance(role)
    role = role:lower()

    for name,list in pairs(Alliances) do
        for _,k in pairs(list) do
            if role:find(k) then
                return name
            end
        end
    end

    return "Unknown"
end

local function IsEnemy(p)
    local my = GetAlliance(GetRole(LocalPlayer))
    local target = GetAlliance(GetRole(p))
    return my ~= target
end

-- WALL CHECK
local function IsVisible(part)
    if not Config.WallCheck then return true end

    local origin = Camera.CFrame.Position
    local dir = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, dir, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- ESP
local ESP = {}

local function CreateESP(p)
    if p == LocalPlayer then return end

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,60)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.Parent = bill

    ESP[p] = {GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- TARGET
local LockedTarget = nil

local function GetTarget()
    local closest,dist = nil,Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and IsEnemy(p) then
            local head = p.Character:FindFirstChild("Head")

            if head and IsVisible(head) then
                local pos,vis = Camera:WorldToViewportPoint(head.Position)

                if vis then
                    local dx = pos.X - Camera.ViewportSize.X/2
                    local dy = pos.Y - Camera.ViewportSize.Y/2
                    local mag = dx*dx + dy*dy

                    if mag < dist then
                        dist = mag
                        closest = head
                    end
                end
            end
        end
    end

    LockedTarget = closest
end

-- LOOP
RunService.RenderStepped:Connect(function()

    -- FOV
    FOVCircle.Radius = Config.FOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    FOVCircle.Visible = Config.Aimbot

    GetTarget()

    -- AIMBOT
    if Config.Aimbot and LockedTarget then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position,LockedTarget.Position)
    end

    -- SILENT
    if Config.SilentAim and LockedTarget then
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.lookAt(Camera.CFrame.Position,LockedTarget.Position),
            0.2
        )
    end

    -- ANTI RECOIL
    if Config.AntiRecoil then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position,Camera.CFrame.Position + Camera.CFrame.LookVector)
    end

    -- ESP LOOP
    for p,data in pairs(ESP) do
        if p and p.Character and Config.ESP then
            local root = p.Character:FindFirstChild("HumanoidRootPart")
            local humanoid = p.Character:FindFirstChildOfClass("Humanoid")

            if root and humanoid then
                local role = GetRole(p)
                local status = IsEnemy(p) and "ENEMY" or "FRIEND"

                local hp = math.floor(humanoid.Health)
                local dist = math.floor((root.Position - Camera.CFrame.Position).Magnitude)

                data.GUI.Adornee = root
                data.GUI.Enabled = true
                data.Text.Text =
                    p.Name.." ["..role.."]\n"..
                    status.." | "..dist.."m\n"..
                    "HP: "..hp

                data.Text.TextColor3 = GetColor(role)
            end
        else
            if data.GUI then data.GUI.Enabled = false end
        end
    end
end)

end

