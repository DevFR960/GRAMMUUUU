repeat task.wait() until game:IsLoaded()

--// LOAD UI
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// KEY
local correctKey = "SINEX_X555"

--// MAIN
function startSINEX()

--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

--// CONFIG
local Config = {
    ESP = true,
    Aimbot = false,
    SilentAim = false,
    TeamCheck = false,
    WallCheck = false,
    Hitbox = false,
    HitboxSize = 5,
    FOV = 200
}

--// UI
local Window = Rayfield:CreateWindow({
    Name = "SINEX_X HUB 💀",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "DELTA / XENO SAFE",
    ConfigurationSaving = {Enabled = false}
})

local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")

--// FOV
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.NumSides = 100
FOVCircle.Filled = false
FOVCircle.Color = Color3.fromRGB(0,255,255)

--// FUNCTIONS
local function GetHealth(c)
    local h=c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

-- ROLE
local function GetRole(p, char)
    if p.Team and p.Team.Name ~= "" then
        return p.Team.Name
    end

    local ls = p:FindFirstChild("leaderstats")
    if ls then
        for _,v in pairs(ls:GetChildren()) do
            if tostring(v.Name):lower():find("team") then
                return tostring(v.Value)
            end
        end
    end

    return "Unknown"
end

-- COLOR
local function GetColor(role)
    role = tostring(role):lower()

    if role:find("scp") then return Color3.fromRGB(255,105,180)
    elseif role:find("class") then return Color3.fromRGB(255,170,0)
    elseif role:find("guard") then return Color3.fromRGB(220,240,255)
    elseif role:find("mtf") then return Color3.fromRGB(0,120,255)
    elseif role:find("chaos") then return Color3.fromRGB(0,200,0)
    elseif role:find("serpent") then return Color3.fromRGB(255,0,0)
    end

    return Color3.fromRGB(255,255,255)
end

-- TEAM CHECK
local function IsEnemy(p, char)
    if not Config.TeamCheck then return true end

    local myRole = GetRole(LocalPlayer, LocalPlayer.Character)
    local targetRole = GetRole(p, char)

    return myRole ~= targetRole
end

-- WALL CHECK
local function IsVisible(part)
    if not Config.WallCheck then return true end

    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, direction, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- ESP
local ESP = {}

local function CreateESP(p)
    if p==LocalPlayer then return end

    local bill=Instance.new("BillboardGui")
    bill.Size=UDim2.new(0,200,0,50)
    bill.AlwaysOnTop=true
    bill.Parent=game.CoreGui

    local txt=Instance.new("TextLabel")
    txt.Size=UDim2.new(1,0,1,0)
    txt.BackgroundTransparency=1
    txt.TextScaled=true
    txt.TextStrokeTransparency=0
    txt.Parent=bill

    ESP[p]={GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- TARGET
local LockedTarget=nil

local function GetTarget()
    local closest=nil
    local shortest=Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer and p.Character then
            local c=p.Character
            local head=c:FindFirstChild("Head")

            if head and GetHealth(c)>0 and IsEnemy(p,c) and IsVisible(head) then
                local pos,vis=Camera:WorldToViewportPoint(head.Position)

                if vis then
                    local dx=pos.X-Camera.ViewportSize.X/2
                    local dy=pos.Y-Camera.ViewportSize.Y/2
                    local dist=dx*dx+dy*dy

                    if dist<shortest then
                        shortest=dist
                        closest=head
                    end
                end
            end
        end
    end

    LockedTarget=closest
end

-- UI
Combat:CreateToggle({Name="Aimbot (Head Lock)",Callback=function(v)Config.Aimbot=v end})
Combat:CreateToggle({Name="Silent Aim (Soft)",Callback=function(v)Config.SilentAim=v end})
Combat:CreateToggle({Name="Team Check",Callback=function(v)Config.TeamCheck=v end})
Combat:CreateToggle({Name="Wall Check",Callback=function(v)Config.WallCheck=v end})
Combat:CreateToggle({Name="Hitbox Expander",Callback=function(v)Config.Hitbox=v end})

Combat:CreateSlider({
    Name="Hitbox Size",
    Range={2,20},
    CurrentValue=5,
    Callback=function(v)Config.HitboxSize=v end
})

Visual:CreateToggle({Name="ESP",Callback=function(v)Config.ESP=v end})

Visual:CreateSlider({
    Name="FOV Size",
    Range={50,400},
    CurrentValue=200,
    Callback=function(v)Config.FOV=v end
})

-- LOOP
RunService.RenderStepped:Connect(function()

    FOVCircle.Radius = Config.FOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    FOVCircle.Visible = Config.Aimbot

    GetTarget()

    if Config.Aimbot and LockedTarget then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)
    end

    if Config.SilentAim and LockedTarget then
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position),
            0.25
        )
    end

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local esp=ESP[p]
            local c=p.Character

            if not esp or not c then continue end

            local root=c:FindFirstChild("HumanoidRootPart")

            if not root or GetHealth(c)<=0 or not Config.ESP or not IsEnemy(p,c) then
                esp.GUI.Enabled=false
                continue
            end

            local hp=math.floor(GetHealth(c))
            local dist=math.floor((root.Position-Camera.CFrame.Position).Magnitude)
            local role=GetRole(p,c)
            local color=GetColor(role)

            esp.GUI.Adornee=root
            esp.GUI.Enabled=true
            esp.Text.Text=p.Name.." ["..role.."]\nHP: "..hp.." | "..dist.."m"
            esp.Text.TextColor3=color

            if Config.Hitbox then
                root.Size=Vector3.new(Config.HitboxSize,Config.HitboxSize,Config.HitboxSize)
                root.Transparency=0.5
                root.CanCollide=false
            end
        end
    end

end)

end

--// KEY UI
local KeyWindow = Rayfield:CreateWindow({
    Name = "SINEX_X HUB - KEY",
    LoadingTitle = "Enter Key",
    LoadingSubtitle = "Mobile Supported",
    ConfigurationSaving = {Enabled = false}
})

KeyWindow:CreateInput({
    Name = "Enter Key",
    PlaceholderText = "Type key here...",
    RemoveTextAfterFocusLost = false,
    Callback = function(text)
        if text == correctKey then
            Rayfield:Notify({
                Title = "Access Granted",
                Content = "Welcome 💀",
                Duration = 3
            })
            task.wait(1)
            KeyWindow:Destroy()
            startSINEX()
        else
            Rayfield:Notify({
                Title = "Wrong Key ❌",
                Content = "Try again",
                Duration = 3
            })
        end
    end
})
