FOVCircle.NumSides = 100
FOVCircle.Filled = false
FOVCircle.Color = Color3.fromRGB(0,255,255)

-- FUNCTIONS
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

local function GetRole(p, char)
    if p.Team and p.Team.Name ~= "" then
        return p.Team.Name
    end
    return "Unknown"
end

-- FRIEND SYSTEM (SCP Retrobreach)
local function IsFriendly(role1, role2)
    role1 = tostring(role1):lower()
    role2 = tostring(role2):lower()

    if (role1:find("scp") and role2:find("serpent")) or
       (role2:find("scp") and role1:find("serpent")) then
        return true
    end

    if (role1:find("mtf") or role1:find("security") or role1:find("foundation")) and
       (role2:find("mtf") or role2:find("security") or role2:find("foundation")) then
        return true
    end

    if (role1:find("chaos") and role2:find("class")) or
       (role2:find("chaos") and role1:find("class")) then
        return true
    end

    return role1 == role2
end

local function IsEnemy(p, char)
    local myRole = GetRole(LocalPlayer, LocalPlayer.Character)
    local targetRole = GetRole(p, char)

    return not IsFriendly(myRole, targetRole)
end

local function GetColor(role)
    role = tostring(role):lower()

    if role:find("class") then return Color3.fromRGB(255,170,0)
    elseif role:find("foundation") then return Color3.fromRGB(255,255,255)
    elseif role:find("security") then return Color3.fromRGB(0,170,255)
    elseif role:find("mtf") then return Color3.fromRGB(0,120,255)
    elseif role:find("chaos") then return Color3.fromRGB(0,255,0)
    elseif role:find("serpent") then return Color3.fromRGB(255,0,0)
    elseif role:find("scp") then return Color3.fromRGB(255,105,180)
    end

    return Color3.fromRGB(255,255,255)
end

local function IsVisible(part)
    if not Config.WallCheck then return true end

    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, direction, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- ESP SYSTEM
local ESP = {}

local function CreateESP(p)
    if p == LocalPlayer then return end
    if ESP[p] then return end

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,50)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.Parent = bill

    ESP[p] = {GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

Players.PlayerRemoving:Connect(function(p)
    if ESP[p] then
        if ESP[p].GUI then ESP[p].GUI:Destroy() end
        ESP[p] = nil
    end
end)

-- TARGET
local LockedTarget = nil

local function GetTarget()
    local closest = nil
    local shortest = Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local c = p.Character
            local head = c:FindFirstChild("Head")

            if head and GetHealth(c) > 0 and IsEnemy(p,c) and IsVisible(head) then
                local pos,vis = Camera:WorldToViewportPoint(head.Position)

                if vis then
                    local dx = pos.X - Camera.ViewportSize.X/2
                    local dy = pos.Y - Camera.ViewportSize.Y/2
                    local dist = dx*dx + dy*dy

                    if dist < shortest then
                        shortest = dist
                        closest = head
                    end
                end
            end
        end
    end

    LockedTarget = closest
end

-- UI
Combat:CreateToggle({Name="Aimbot",Callback=function(v)Config.Aimbot=v end})
Combat:CreateToggle({Name="Silent Aim",Callback=function(v)Config.SilentAim=v end})
