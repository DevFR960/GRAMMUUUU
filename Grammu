local Camera = workspace.CurrentCamera

-- CONFIG
local Config = {
    ESP = true,
    Aimbot = false,
    SilentAim = false,
    TeamCheck = false,
    WallCheck = false,
    Hitbox = false,
    HitboxSize = 5,
    FOV = 200
}

-- UI
