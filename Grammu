--// MAIN FUNCTION
local function startSINEX()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local Config = {
    ESP = true,
    Aimbot = false,
    SilentAim = false,
    WallCheck = false,
    Hitbox = false,
    HitboxSize = 5,
    FOV = 200
}

local Window = Rayfield:CreateWindow({
    Name = "SINEX_X HUB 💀",
    LoadingTitle = "Loaded",
    LoadingSubtitle = "SAFE MODE",
    ConfigurationSaving = {Enabled = false}
})

local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")

-- FOV
local FOV = Instance.new("Frame")
FOV.Size = UDim2.new(0,200,0,200)
FOV.AnchorPoint = Vector2.new(0.5,0.5)
FOV.Position = UDim2.new(0.5,0,0.5,0)
FOV.BackgroundTransparency = 1
FOV.Parent = game.CoreGui

Instance.new("UICorner",FOV).CornerRadius = UDim.new(1,0)
Instance.new("UIStroke",FOV).Thickness = 2

-- Health
local function GetHealth(c)
    local h=c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

-- WallCheck
local function IsVisible(part)
    if not Config.WallCheck then return true end
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, direction, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- ESP
local ESP = {}

local function CreateESP(p)
    if p==LocalPlayer then return end

    local gui = Instance.new("BillboardGui")
    gui.Size = UDim2.new(0,200,0,50)
    gui.AlwaysOnTop = true
    gui.Parent = game.CoreGui

    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.TextScaled = true
    text.TextStrokeTransparency = 0
    text.Parent = gui

    ESP[p] = {GUI=gui,Text=text}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- Target
local LockedTarget=nil

local function GetTarget()
    local closest=nil
    local shortest=Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer and p.Character then
            local head=p.Character:FindFirstChild("Head")
            if head and GetHealth(p.Character)>0 and IsVisible(head) then
                local pos,vis=Camera:WorldToViewportPoint(head.Position)
                if vis then
                    local dx=pos.X-Camera.ViewportSize.X/2
                    local dy=pos.Y-Camera.ViewportSize.Y/2
                    local dist=dx*dx+dy*dy
                    if dist<shortest then
                        shortest=dist
                        closest=head
                    end
                end
            end
        end
    end

    LockedTarget=closest
end

-- UI
Combat:CreateToggle({Name="Aimbot",Callback=function(v)Config.Aimbot=v end})
Combat:CreateToggle({Name="Silent Aim",Callback=function(v)Config.SilentAim=v end})
Combat:CreateToggle({Name="Wall Check",Callback=function(v)Config.WallCheck=v end})
Combat:CreateToggle({Name="Hitbox",Callback=function(v)Config.Hitbox=v end})

Visual:CreateToggle({Name="ESP",Callback=function(v)Config.ESP=v end})

-- LOOP
RunService.RenderStepped:Connect(function()

    FOV.Visible = Config.Aimbot
    GetTarget()

    if Config.Aimbot and LockedTarget then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)
    end

    if Config.SilentAim and LockedTarget then
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position), 0.3
        )
    end

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local esp=ESP[p]
            local c=p.Character

            if not esp or not c then continue end

            local root=c:FindFirstChild("HumanoidRootPart")
            if not root or GetHealth(c)<=0 or not Config.ESP then
                esp.GUI.Enabled=false
                continue
            end

            local hp=math.floor(GetHealth(c))
            local dist=math.floor((root.Position-Camera.CFrame.Position).Magnitude)

            esp.GUI.Adornee=root
            esp.GUI.Enabled=true
            esp.Text.Text=p.Name.." | HP:"..hp.." | "..dist.."m"

            if Config.Hitbox then
                root.Size=Vector3.new(5,5,5)
                root.Transparency=0.5
            end
        end
    end

end)

end

--// BUTTON CLICK
Button.MouseButton1Click:Connect(function()
    if Box.Text == correctKey then
        ScreenGui:Destroy()
        startSINEX()
    else
        Box.Text = "Wrong Key!"
    end
end)
