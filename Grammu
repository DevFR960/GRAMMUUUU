-- FUNCTIONS
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

local function GetRole(p)
    return (p.Team and p.Team.Name) or "Unknown"
end

-- NORMALIZE
local function Normalize(role)
    role = string.lower(role)
    if role:find("serpent") then return "serpent" end
    if role:find("scp") then return "scp" end
    if role:find("mtf") then return "mtf" end
    if role:find("security") then return "security" end
    if role:find("facility") then return "facility" end
    if role:find("chaos") then return "chaos" end
    if role:find("class") then return "classd" end
    return "unknown"
end

-- FRIEND SYSTEM
local function IsFriendly(role1, role2)
    role1 = Normalize(role1)
    role2 = Normalize(role2)

    if role1 == role2 then return true end

    if (role1=="serpent" and role2=="scp") or (role1=="scp" and role2=="serpent") then
        return true
    end

    local g1 = (role1=="mtf" or role1=="security" or role1=="facility")
    local g2 = (role2=="mtf" or role2=="security" or role2=="facility")
    if g1 and g2 then return true end

    if (role1=="chaos" and role2=="classd") or (role1=="classd" and role2=="chaos") then
        return true
    end

    return false
end

local function IsEnemy(p)
    if Config.ShootAll then return true end
    if not Config.TeamCheck then return true end
    return not IsFriendly(GetRole(LocalPlayer), GetRole(p))
end

local function GetColor(role)
    role = tostring(role):lower()
    if role:find("scp") then return Color3.fromRGB(255,105,180)
    elseif role:find("class") then return Color3.fromRGB(255,170,0)
    elseif role:find("security") then return Color3.fromRGB(220,240,255)
    elseif role:find("mtf") then return Color3.fromRGB(0,120,255)
    elseif role:find("chaos") then return Color3.fromRGB(0,200,0)
    elseif role:find("serpent") then return Color3.fromRGB(255,0,0)
    end
    return Color3.fromRGB(255,255,255)
end

local function IsVisible(part)
    if not Config.WallCheck then return true end
    local origin = Camera.CFrame.Position
    local direction = (part.Position - origin)

    local params = RaycastParams.new()
    params.FilterDescendantsInstances = {LocalPlayer.Character}
    params.FilterType = Enum.RaycastFilterType.Blacklist

    local result = workspace:Raycast(origin, direction, params)
    return not result or result.Instance:IsDescendantOf(part.Parent)
end

-- HIT PART
local function GetHitPart(char)
    if Config.HeadPriority then
        return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    end

    if Config.HitPart == "Head" then
        return char:FindFirstChild("Head")
    elseif Config.HitPart == "Root" then
        return char:FindFirstChild("HumanoidRootPart")
    else
        local parts = {"Head","HumanoidRootPart"}
        return char:FindFirstChild(parts[math.random(1,#parts)])
    end
end

-- ESP
local ESP = {}

local function CreateESP(p)
