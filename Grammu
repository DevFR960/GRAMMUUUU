-- LOOP (OPTIMIZED)
local last = 0

RunService.RenderStepped:Connect(function()
    if tick() - last < 0.1 then return end
    last = tick()

    -- FOV
    FOVCircle.Radius = Config.FOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    FOVCircle.Visible = Config.Aimbot

    -- TARGET UPDATE
    if tick() - targetTick > 0.1 then
        targetTick = tick()
        GetTarget()
    end

    -- AIMBOT
    if Config.Aimbot and LockedTarget then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)
    end

    if Config.SilentAim and LockedTarget then
        Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position),
            0.25
        )
    end

    -- ESP
    for p,esp in pairs(ESP) do
        if not p or not p.Parent then continue end

        local c = p.Character
        if not c then
            esp.GUI.Enabled = false
            continue
        end

        local root = c:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        local dist = (root.Position - Camera.CFrame.Position).Magnitude

        if dist > MAX_DISTANCE or GetHealth(c) <= 0 or not Config.ESP then
            esp.GUI.Enabled = false
        else
            esp.GUI.Adornee = root
            esp.GUI.Enabled = true

            if tick() - espUpdateTick > 0.2 then
                local hp = math.floor(GetHealth(c))
                local role = GetRole(p,c)

                local status = IsEnemy(p,c) and "ENEMY" or "FRIEND"

                esp.Text.Text = p.Name.." ["..role.."]\n"..status.." | "..math.floor(dist).."m\nHP: "..hp
                esp.Text.TextColor3 = GetColor(role)
            end
        end

        -- HITBOX FIX
        if Config.Hitbox and root and root.Size.X ~= Config.HitboxSize then
            root.Size = Vector3.new(Config.HitboxSize,Config.HitboxSize,Config.HitboxSize)
            root.Transparency = 0.5
            root.CanCollide = false
        elseif root then
            root.Size = Vector3.new(2,2,1)
            root.Transparency = 0
            root.CanCollide = true
        end
    end
end)

end

