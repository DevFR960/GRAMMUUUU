-- FUNCTIONS
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

local function GetRole(p)
    return (p.Team and p.Team.Name) or "Unknown"
end

local function Normalize(role)
    role = string.lower(role)
    if role:find("serpent") then return "serpent" end
    if role:find("scp") then return "scp" end
    if role:find("mtf") then return "mtf" end
    if role:find("security") then return "security" end
    if role:find("facility") then return "facility" end
    if role:find("chaos") then return "chaos" end
    if role:find("class") then return "classd" end
    return "unknown"
end

local function IsFriendly(role1, role2)
    role1 = Normalize(role1)
    role2 = Normalize(role2)

    if role1 == role2 then return true end
    if (role1=="serpent" and role2=="scp") or (role1=="scp" and role2=="serpent") then return true end

    local g1 = (role1=="mtf" or role1=="security" or role1=="facility")
    local g2 = (role2=="mtf" or role2=="security" or role2=="facility")
    if g1 and g2 then return true end

    if (role1=="chaos" and role2=="classd") or (role1=="classd" and role2=="chaos") then return true end

    return false
end

local function IsEnemy(p)
    if Config.ShootAll then return true end
    if not Config.TeamCheck then return true end
    return not IsFriendly(GetRole(LocalPlayer), GetRole(p))
end

local function GetHitPart(char)
    if Config.HeadPriority then
        return char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    end

    if Config.HitPart == "Head" then
        return char:FindFirstChild("Head")
    else
        return char:FindFirstChild("HumanoidRootPart")
    end
end

-- ESP
local ESP = {}

local function CreateESP(p)
    if p == LocalPlayer then return end

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,50)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.Parent = bill

    ESP[p] = {GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- TARGET
local LockedTarget = nil

local function GetTarget()
    local closest = nil
    local shortest = Config.FOV * Config.FOV

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and IsEnemy(p) then
            local c = p.Character
            local part = GetHitPart(c)

            if part and GetHealth(c) > 0 then
                local pos,vis = Camera:WorldToViewportPoint(part.Position)

                if vis then
                    local dx = pos.X - Camera.ViewportSize.X/2
                    local dy = pos.Y - Camera.ViewportSize.Y/2
                    local dist = dx*dx + dy*dy

                    if dist < shortest then
                        shortest = dist
                        closest = part
                    end
                end
            end
        end
    end

    LockedTarget = closest
end

