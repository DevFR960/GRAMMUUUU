-- HEALTH
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

-- PLAYER ESP
local ESP = {}

local function CreateESP(p)
    if p == LocalPlayer then return end

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,50)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.Parent = bill

    ESP[p] = {GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

Players.PlayerRemoving:Connect(function(p)
    if ESP[p] then
        ESP[p].GUI:Destroy()
        ESP[p] = nil
    end
end)

-- KEYCARD ESP
local KeyESP = {}
local KeyESPEnabled = false

local function CreateKeyESP(obj)
    if not obj:IsA("Tool") then return end
    if not obj.Name:lower():find("keycard") then return end
    if KeyESP[obj] then return end

    local handle = obj:FindFirstChild("Handle")
    if not handle then return end

    local hl = Instance.new("Highlight")
    hl.FillColor = Color3.fromRGB(0,255,0)
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Adornee = obj
    hl.Parent = game.CoreGui

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,40)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.TextColor3 = Color3.fromRGB(0,255,0)
    txt.Parent = bill

    KeyESP[obj] = {HL=hl,Bill=bill,Text=txt,Handle=handle}
end

local function RemoveKeyESP(obj)
    if KeyESP[obj] then
        if KeyESP[obj].HL then KeyESP[obj].HL:Destroy() end
        if KeyESP[obj].Bill then KeyESP[obj].Bill:Destroy() end
        KeyESP[obj] = nil
    end
end

local function ScanKeys()
    for _,v in pairs(workspace:GetDescendants()) do
        CreateKeyESP(v)
    end
end

-- KEYCARD TP
local function GetNearestKey()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local closest,dist = nil,80

    for _,v in pairs(workspace:GetDescendants()) do
        if v:IsA("Tool") and v.Name:lower():find("keycard") then
            local h = v:FindFirstChild("Handle")
            if h then
                local d = (h.Position - root.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
    end

    return closest
end

local function TPKey()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")

    local key = GetNearestKey()
    if key and key:FindFirstChild("Handle") then
        root.CFrame = key.Handle.CFrame + Vector3.new(0,2,0)
    end
end

-- GUN DETECTION (STRUCTURE BASED)
local function IsGun(tool)
    if not tool:IsA("Tool") then return false end

    local handle = tool:FindFirstChild("Handle")
    if not handle then return false end

    local name = tool.Name:lower()

    if name:find("keycard") or name:find("med") then
        return false
    end

    if tool:FindFirstChildOfClass("Script") 
    or tool:FindFirstChildOfClass("LocalScript")
    or tool:FindFirstChild("Ammo") then
        return true
    end

    return false
end

-- GUN TP
local function GetNearestGun()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end

    local closest,dist = nil,100

    for _,v in pairs(workspace:GetDescendants()) do
        if IsGun(v) then
            local h = v:FindFirstChild("Handle")
            if h then
                local d = (h.Position - root.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = v
                end
            end
        end
    end

    return closest
end

local function TPGun()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")

    local gun = GetNearestGun()
    if gun and gun:FindFirstChild("Handle") then
        root.CFrame = gun.Handle.CFrame + Vector3.new(0,2,0)
    end
end

-- UI
Combat:CreateToggle({Name="Aimbot",Callback=function(v)Config.Aimbot=v end})
Combat:CreateToggle({Name="Silent Aim",Callback=function(v)Config.SilentAim=v end})

Visual:CreateToggle({Name="Player ESP",Callback=function(v)Config.ESP=v end})

ItemTab:CreateToggle({
