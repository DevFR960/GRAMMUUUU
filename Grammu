local correctKey = "SINEX_X555"

function startSINEX()

local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local Config = {
    ESP = true,
    Aimbot = false,
    ShootEveryone = false,
    Hitbox = false,
    AntiRecoil = true,
    HardLock = true,
    FOV = 200
}

-- UI
local Window = Rayfield:CreateWindow({
    Name = "SINEX_X HUB 💀 FINAL",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "RETROBREACH OP",
    ConfigurationSaving = {Enabled = false}
})

local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")

-- FOV
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.NumSides = 100
FOVCircle.Filled = false
FOVCircle.Color = Color3.fromRGB(0,255,255)

-- FUNCTIONS
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

local function GetRole(p)
    return (p.Team and p.Team.Name) or "Unknown"
end

-- 🎨 สี Role ตรงเกม
local function GetColor(role)
    role = role:lower()
    if role:find("class") then return Color3.fromRGB(255,140,0)
    elseif role:find("security") then return Color3.fromRGB(0,170,255)
    elseif role:find("mtf") then return Color3.fromRGB(0,85,255)
    elseif role:find("facility") then return Color3.fromRGB(0,200,255)
    elseif role:find("chaos") then return Color3.fromRGB(0,255,0)
    elseif role:find("serpent") then return Color3.fromRGB(170,0,255)
    elseif role:find("goc") then return Color3.fromRGB(255,255,255)
    elseif role:find("scp") then return Color3.fromRGB(255,0,0)
    end
    return Color3.fromRGB(255,255,255)
end

-- 🤝 ทีม
local function IsFriendly(a, b)
    a = a:lower()
    b = b:lower()

    if (a:find("scp") and b:find("serpent")) or (a:find("serpent") and b:find("scp")) then return true end

    if (a:find("mtf") or a:find("security") or a:find("facility")) and
       (b:find("mtf") or b:find("security") or b:find("facility")) then return true end

    if (a:find("chaos") and b:find("class")) or (a:find("class") and b:find("chaos")) then return true end

    return false
end

local function IsEnemy(p)
    if Config.ShootEveryone then return true end
    local myRole = GetRole(LocalPlayer)
    local role = GetRole(p)
    return not IsFriendly(myRole, role)
end

-- ESP
local ESP = {}

local function CreateESP(p)
    if p == LocalPlayer then return end

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,60)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.Parent = bill

    ESP[p] = {GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

-- TARGET
local LockedTarget = nil

local function GetTarget()
    local closest, shortest = nil, Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and IsEnemy(p) then
            local head = p.Character:FindFirstChild("Head")
            if head and GetHealth(p.Character) > 0 then

                local pos,vis = Camera:WorldToViewportPoint(head.Position)
                if vis then
                    local dx = pos.X - Camera.ViewportSize.X/2
                    local dy = pos.Y - Camera.ViewportSize.Y/2
                    local dist = dx*dx + dy*dy

                    if dist < shortest then
                        shortest = dist
                        closest = head
                    end
                end
            end
        end
    end

    LockedTarget = closest
end

-- UI Controls
Combat:CreateToggle({Name="Aimbot",Callback=function(v)Config.Aimbot=v end})
Combat:CreateToggle({Name="Shoot Everyone",Callback=function(v)Config.ShootEveryone=v end})
Combat:CreateToggle({Name="Hitbox",Callback=function(v)Config.Hitbox=v end})
Combat:CreateToggle({Name="Anti Recoil",Callback=function(v)Config.AntiRecoil=v end})
Combat:CreateToggle({Name="Hard Lock",Callback=function(v)Config.HardLock=v end})

Visual:CreateToggle({Name="ESP",Callback=function(v)Config.ESP=v end})

Visual:CreateSlider({
    Name="FOV",
    Range={50,400},
    CurrentValue=200,
    Callback=function(v)Config.FOV=v end
})

-- LOOP
RunService.RenderStepped:Connect(function()

    FOVCircle.Radius = Config.FOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    FOVCircle.Visible = Config.Aimbot

    GetTarget()

    if Config.Aimbot and LockedTarget then
        local aim = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)

        if Config.HardLock then
            Camera.CFrame = aim
        else
            Camera.CFrame = Camera.CFrame:Lerp(aim, 0.2)
        end
    end

    -- Anti recoil
    if Config.AntiRecoil then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + Camera.CFrame.LookVector)
    end

    -- ESP
    for p,esp in pairs(ESP) do
        if p and p.Character then
            local root = p.Character:FindFirstChild("HumanoidRootPart")

            if root and GetHealth(p.Character) > 0 and Config.ESP then
                local role = GetRole(p)
                local myRole = GetRole(LocalPlayer)
                local status = IsFriendly(myRole, role) and "🤝 FRIEND" or "⚔️ ENEMY"

                esp.GUI.Adornee = root
                esp.GUI.Enabled = true
                esp.Text.Text = p.Name.." ["..role.."]\n"..status
                esp.Text.TextColor3 = GetColor(role)
            else
                esp.GUI.Enabled = false
            end
        end
    end
end)

end

