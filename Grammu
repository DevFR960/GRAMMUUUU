RunService.RenderStepped:Connect(function()

    if DrawingSupported and FOVCircle then
        FOVCircle.Radius = Config.FOV
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
        FOVCircle.Visible = true
    end

    GetTarget()

    if Config.Aimbot and LockedTarget then
        local targetCF = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)

        if Config.HardLock then
            Camera.CFrame = targetCF
        else
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, Config.Smoothness)
        end

        if Config.AntiRecoil then
            Camera.CFrame = targetCF
        end
    end

    for p,esp in pairs(ESP) do
        local c = p.Character
        if not c then continue end

        local root = c:FindFirstChild("HumanoidRootPart")

        if root and GetHealth(c) > 0 and Config.ESP then
            local role = GetRole(p)
            local status = IsFriendly(GetRole(LocalPlayer), role) and "🤝 FRIEND" or "⚔️ ENEMY"

            esp.GUI.Adornee = root
            esp.GUI.Enabled = true
            esp.Text.Text = p.Name.." ["..role.."]\n"..status
        else
            esp.GUI.Enabled = false
        end

        if Config.Hitbox and root then
            root.Size = Vector3.new(10,10,10)
            root.Transparency = 0.5
            root.CanCollide = false
        end
    end
end)

