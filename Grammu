        KeyESPEnabled = v
        if v then ScanKeys() else
            for k,_ in pairs(KeyESP) do RemoveKeyESP(k) end
        end
    end
})

ItemTab:CreateButton({
    Name="TP Nearest Keycard",
    Callback=function()
        TPKey()
    end
})

ItemTab:CreateButton({
    Name="TP Nearest Gun",
    Callback=function()
        TPGun()
    end
})

-- LOOP OPTIMIZED
local last = 0
RunService.RenderStepped:Connect(function()
    if tick() - last < 0.05 then return end
    last = tick()

    FOVCircle.Radius = Config.FOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2,Camera.ViewportSize.Y/2)
    FOVCircle.Visible = Config.Aimbot

    for p,esp in pairs(ESP) do
        if not p or not p.Parent then
            esp.GUI:Destroy()
            ESP[p] = nil
            continue
        end

        local c = p.Character
        if not c or not Config.ESP then
            esp.GUI.Enabled = false
            continue
        end

        local root = c:FindFirstChild("HumanoidRootPart")
        if not root or GetHealth(c) <= 0 then
            esp.GUI.Enabled = false
            continue
        end

        esp.GUI.Adornee = root
        esp.GUI.Enabled = true
        esp.Text.Text = p.Name
    end

    if KeyESPEnabled then
        for obj,data in pairs(KeyESP) do
            if not obj or not obj.Parent then
                RemoveKeyESP(obj)
                continue
            end

            local pos = data.Handle.Position
            local dist = math.floor((pos - Camera.CFrame.Position).Magnitude)

            data.Bill.Adornee = data.Handle
            data.Text.Text = obj.Name.." ["..dist.."m]"
        end
    end
end)

workspace.DescendantAdded:Connect(function(v)
    if KeyESPEnabled then
        task.wait(0.2)
        CreateKeyESP(v)
    end
end)

end

