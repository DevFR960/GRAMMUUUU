--// LOAD UI
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

--// KEY
local correctKey = "SINEX_X555"

--// MAIN FUNCTION
local function startSINEX()

--// SERVICES
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

--// CONFIG
local Config = {
    ESP = true,
    Aimbot = false,
    TeamCheck = false,
    FOV = 200,
    ShowFOV = true
}

--// UI
local Window = Rayfield:CreateWindow({
    Name = "SINEX_X HUB 💀",
    LoadingTitle = "Loading...",
    LoadingSubtitle = "XENO / DELTA SAFE",
    ConfigurationSaving = {Enabled = false}
})

local Combat = Window:CreateTab("Combat")
local Visual = Window:CreateTab("Visual")

--// FOV (GUI VERSION FOR DELTA)
local FOVFrame = Instance.new("Frame")
FOVFrame.Size = UDim2.new(0,200,0,200)
FOVFrame.AnchorPoint = Vector2.new(0.5,0.5)
FOVFrame.Position = UDim2.new(0.5,0,0.5,0)
FOVFrame.BackgroundTransparency = 1
FOVFrame.Parent = game.CoreGui

local Stroke = Instance.new("UIStroke", FOVFrame)
Stroke.Thickness = 2
Stroke.Color = Color3.fromRGB(0,255,255)

local Corner = Instance.new("UICorner", FOVFrame)
Corner.CornerRadius = UDim.new(1,0)

--// STORAGE
local ESP = {}
local LockedTarget = nil

--// ROLE
local function GetRole(p, c)
    if p.Team then return p.Team.Name end
    return "Unknown"
end

--// COLORS
local function GetRoleColor(role)
    role = tostring(role):lower()

    if role:find("scp") then return Color3.fromRGB(255,105,180)
    elseif role:find("class") then return Color3.fromRGB(255,170,0)
    elseif role:find("guard") then return Color3.fromRGB(150,200,255)
    elseif role:find("chaos") then return Color3.fromRGB(0,200,0)
    elseif role:find("serpent") then return Color3.fromRGB(255,0,0)
    elseif role:find("mtf") then return Color3.fromRGB(0,120,255)
    end

    return Color3.fromRGB(255,255,255)
end

--// HEALTH
local function GetHealth(c)
    local h = c:FindFirstChildOfClass("Humanoid")
    return h and h.Health or 0
end

--// ESP
local function CreateESP(p)
    if p == LocalPlayer then return end

    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,200,0,50)
    bill.AlwaysOnTop = true
    bill.Parent = game.CoreGui

    local txt = Instance.new("TextLabel")
    txt.Size = UDim2.new(1,0,1,0)
    txt.BackgroundTransparency = 1
    txt.TextScaled = true
    txt.TextStrokeTransparency = 0
    txt.Parent = bill

    ESP[p] = {GUI=bill,Text=txt}
end

for _,p in pairs(Players:GetPlayers()) do CreateESP(p) end
Players.PlayerAdded:Connect(CreateESP)

--// TARGET
local function GetTarget()
    local closest=nil
    local shortest=Config.FOV^2

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer and p.Character then
            local head=p.Character:FindFirstChild("Head")
            if head and GetHealth(p.Character)>0 then
                local pos,vis=Camera:WorldToViewportPoint(head.Position)
                if vis then
                    local dx=pos.X-Camera.ViewportSize.X/2
                    local dy=pos.Y-Camera.ViewportSize.Y/2
                    local dist=dx*dx+dy*dy
                    if dist<shortest then
                        shortest=dist
                        closest=head
                    end
                end
            end
        end
    end

    LockedTarget=closest
end

--// UI
Combat:CreateToggle({
    Name = "Aimbot (Head Lock)",
    CurrentValue = false,
    Callback = function(v) Config.Aimbot=v end
})

Visual:CreateToggle({
    Name = "ESP",
    CurrentValue = true,
    Callback = function(v) Config.ESP=v end
})

Visual:CreateSlider({
    Name = "FOV Size",
    Range = {50,400},
    CurrentValue = 200,
    Callback = function(v)
        Config.FOV=v
        FOVFrame.Size = UDim2.new(0,v,0,v)
    end
})

--// LOOP
RunService.RenderStepped:Connect(function()

    FOVFrame.Visible = Config.ShowFOV and Config.Aimbot

    GetTarget()

    if Config.Aimbot and LockedTarget then
        Camera.CFrame = CFrame.lookAt(Camera.CFrame.Position, LockedTarget.Position)
    end

    for _,p in pairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local esp=ESP[p]
            local c=p.Character
            if not esp or not c then continue end

            local root=c:FindFirstChild("HumanoidRootPart")
            if not root or GetHealth(c)<=0 or not Config.ESP then
                esp.GUI.Enabled=false
                continue
            end

            local role=GetRole(p,c)
            local color=GetRoleColor(role)

            esp.GUI.Adornee=root
            esp.GUI.Enabled=true
            esp.Text.Text=p.Name.." ["..role.."]"
            esp.Text.TextColor3=color
        end
    end

end)

end

--// KEY UI
local KeyWindow = Rayfield:CreateWindow({
    Name = "SINEX_X HUB - KEY",
    LoadingTitle = "Enter Key",
    LoadingSubtitle = "Mobile Supported",
    ConfigurationSaving = {Enabled = false}
})

KeyWindow:CreateInput({
    Name = "Enter Key",
    PlaceholderText = "SINEX_X555",
    Callback = function(text)
        if text == correctKey then
            Rayfield:Notify({Title="Access Granted",Content="Welcome 💀",Duration=3})
            task.wait(1)
            KeyWindow:Destroy()
            startSINEX()
        else
            Rayfield:Notify({Title="Wrong Key",Content="❌",Duration=3})
        end
    end
})
